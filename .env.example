# =============================================================================
# Apex Ground Works — environment template
# =============================================================================
# Copy this file to `.env` in the repo root (never commit real values).
# Git ignores `.env`; `.env.example` stays tracked.
#
# Quick start:
#   1. Fill Supabase values from Dashboard → Project Settings → API.
#   2. Add SUPABASE_ACCESS_TOKEN (Dashboard → Account → Access Tokens) for CLI deploys.
#   3. `npx supabase link --project-ref YOUR_PROJECT_REF`
#   4. `npm run db:push` — applies `supabase/migrations/*.sql`
#   5. Set Edge Function secrets (Dashboard → Edge Functions → Secrets, or CLI):
#        supabase secrets set --env-file .env
#   6. Deploy function: `npm run deploy:function` or `npm run functions:deploy`
#
# See also: docs/SUPABASE-SETUP.md, docs/BACKEND-ARCHITECTURE.md
# =============================================================================

# --- Supabase (Dashboard → Project Settings → API) -----------------------------
# Project URL — "Project URL" field (https://<project_ref>.supabase.co)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Short id from the URL above (same as subdomain before .supabase.co)
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Personal Access Token — CLI (`supabase link`, `functions deploy`) and
# `npm run deploy:function` (Dashboard → Account → Access Tokens)
SUPABASE_ACCESS_TOKEN=

# anon / public key — safe for browser apps with Row Level Security enabled
SUPABASE_ANON_KEY=your_anon_key_here

# service_role — bypasses RLS; Edge Functions and trusted server scripts ONLY.
# Never put this in static HTML, Vite `VITE_*`, or public repos.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Edge Function: CORS ------------------------------------------------------
# Comma-separated list of allowed browser origins (no trailing slashes).
# Local static server examples: http://127.0.0.1:5500,http://localhost:5500
# Production: https://your-domain.com
PUBLIC_SITE_ORIGIN=http://127.0.0.1:5500,http://localhost:5500

# --- Edge Function: optional AI summary (OpenAI) ------------------------------
# If unset, quotes are stored with status `submitted` and no AI fields.
OPENAI_API_KEY=

# --- Edge Function: optional bot check (Cloudflare Turnstile) -----------------
# Site key: safe to expose in HTML later when you add the Turnstile widget.
TURNSTILE_SITE_KEY=
# Secret: verify token in Edge Function only (set as function secret).
TURNSTILE_SECRET_KEY=

# --- Future admin app (`admin/`) — Vite requires VITE_ prefix -----------------
# Use the SAME values as SUPABASE_URL and SUPABASE_ANON_KEY above.
# Never use the service role key in Vite.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
